# ============================================================
# Backend environment variables
# Copy to ".env" and fill in. On EC2 these are written by
# infra/bootstrap.sh from CloudFormation parameters/outputs.
# ============================================================

# --- HTTP server ---
PORT=4000

# --- RDS MySQL connection ---
# DB_HOST = RDS endpoint (CloudFormation output "DBEndpoint").
DB_HOST=localhost
DB_PORT=3306
DB_USER=admin
# DB_PASS = the DBPassword you passed to CloudFormation. << FILL MANUALLY >>
DB_PASS=CHANGE_ME_strong_password
DB_NAME=absensi

# --- Auth ---
# JWT_SECRET = any long random string. << FILL MANUALLY >>
JWT_SECRET=CHANGE_ME_long_random_secret
JWT_EXPIRES_IN=12h

# --- AWS S3 (enrollment photos) ---
AWS_REGION=us-east-1
# S3_BUCKET = CloudFormation output "PhotoBucket".
S3_BUCKET=CHANGE_ME_bucket_name
# Presigned URL lifetime (seconds)
S3_PRESIGN_EXPIRES=300

# --- Face matching ---
# Maximum Euclidean distance to accept a face match (lower = stricter).
MATCH_THRESHOLD=0.5

# --- CORS ---
# Comma-separated list of allowed frontend origins. Use * for demo.
CORS_ORIGIN=*
